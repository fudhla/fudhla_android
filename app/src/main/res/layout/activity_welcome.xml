<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFF"
    tools:context=".pertemuan_3.WelcomeActivity">

    <View
        android:id="@+id/headerGradient"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@drawable/bg_header_wave"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LOKASI ANDA SAAT INI"
                        android:textColor="#FFFFFF"
                        android:alpha="0.8"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Desa Fudhla"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/foto_profile"
                    app:strokeColor="#FFFFFF"
                    app:strokeWidth="2dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.SmallComponent" />
            </RelativeLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/tvWelcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Halo Fudhla! 👋"
                        android:textColor="#333333"
                        android:textSize="26sp"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Ada 12 fasilitas desa yang bisa kamu pinjam hari ini."
                        android:textColor="#64748B"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/bg_rounded_container"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@android:drawable/ic_menu_search"
                            app:tint="#94A3B8" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Cari nama fasilitas..."
                            android:textColor="#94A3B8" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Kategori Fasilitas"
                android:textColor="#1E293B"
                android:textSize="20sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold" />

            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/menuGridLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:padding="4dp"
                app:columnCount="3"
                app:useDefaultMargins="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFasilitasBalai"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="105dp"
                    android:text="🏛️\nBalai Desa"
                    android:textSize="11sp"
                    android:textColor="#1E293B"
                    android:gravity="center"
                    app:strokeColor="#E2E8F0"
                    app:cornerRadius="16dp"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFasilitasSport"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="105dp"
                    android:text="⚽\nLapangan"
                    android:textSize="11sp"
                    android:textColor="#1E293B"
                    android:gravity="center"
                    app:strokeColor="#E2E8F0"
                    app:cornerRadius="16dp"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFasilitasMobil"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="105dp"
                    android:text="🚗\nMobil Siaga"
                    android:textSize="11sp"
                    android:textColor="#1E293B"
                    android:gravity="center"
                    app:strokeColor="#E2E8F0"
                    app:cornerRadius="16dp"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFasilitasTenda"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="105dp"
                    android:text="⛺\nTenda RT"
                    android:textSize="11sp"
                    android:textColor="#1E293B"
                    android:gravity="center"
                    app:strokeColor="#E2E8F0"
                    app:cornerRadius="16dp"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFasilitasAudio"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="105dp"
                    android:text="🔊\nSound"
                    android:textSize="11sp"
                    android:textColor="#1E293B"
                    android:gravity="center"
                    app:strokeColor="#E2E8F0"
                    app:cornerRadius="16dp"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFasilitasTani"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="105dp"
                    android:text="🚜\nAlat Tani"
                    android:textSize="11sp"
                    android:textColor="#1E293B"
                    android:gravity="center"
                    app:strokeColor="#E2E8F0"
                    app:cornerRadius="16dp"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal" />

            </androidx.gridlayout.widget.GridLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Filter Cepat"
                android:textColor="#1E293B"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSemua"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:layout_marginEnd="8dp"
                        android:text="🌟 Semua" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipGedung"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="🏛️ Gedung" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipLapangan"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="⚽ Lapangan" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipKendaraan"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚗 Kendaraan" />
                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="190dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#E2E8F0"
                            android:scaleType="centerCrop"
                            android:src="@drawable/balai_desa" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="16dp"
                            android:background="@drawable/design_fab_background"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="8dp"
                            android:text="UNGGULAN"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:backgroundTint="#F87171"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Balai Desa Serbaguna Fudhla"
                            android:textSize="20sp"
                            android:fontFamily="sans-serif-medium"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Jl. Melati No. 12, Fudhla Jaya"
                            android:textColor="#456AA8"
                            android:textSize="13sp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="16dp"
                            android:background="#F1F5F9" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDetailInventaris"
                            android:layout_width="match_parent"
                            android:layout_height="58dp"
                            android:text="Formulir Peminjaman"
                            android:textAllCaps="false"
                            android:textStyle="bold"
                            app:cornerRadius="16dp"
                            app:backgroundTint="#03A9F4" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackToDashboard"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="40dp"
                android:text="Kembali ke Dashboard Utama"
                android:textColor="#888888"
                android:textAllCaps="false" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>