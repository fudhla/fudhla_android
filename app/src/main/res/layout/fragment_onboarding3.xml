<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <View
        android:id="@+id/blueHeader"
        android:layout_width="match_parent"
        android:layout_height="360dp"
        android:background="@drawable/bg_onboarding_header"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imgOnboard3"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:src="@drawable/on3"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="@+id/blueHeader"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="40dp" />

    <TextView
        android:id="@+id/txtTitle3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Layanan Pengaduan Warga"
        android:textAlignment="center"
        android:textColor="@color/text_title_dark"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="50dp"
        android:layout_marginHorizontal="32dp"
        app:layout_constraintTop_toBottomOf="@+id/blueHeader"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/txtDesc3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Laporkan kendala infrastruktur atau lingkungan sekitar secara cepat langsung ke admin desa."
        android:textAlignment="center"
        android:textColor="@color/text_desc_gray"
        android:textSize="15sp"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="40dp"
        android:lineSpacingExtra="4dp"
        app:layout_constraintTop_toBottomOf="@+id/txtTitle3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnStart"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="AYO MULAI"
        android:textColor="@color/white"
        android:backgroundTint="@color/bina_desa_blue"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginHorizontal="36dp"
        android:layout_marginBottom="32dp"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>